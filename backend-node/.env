# InsightMail — Node.js Backend Environment Variables
# Copy this file to .env and fill in values before running.

# Server port (default: 3001)
PORT=3001

# Java Spring Boot mail service URL
JAVA_SERVICE_URL=http://localhost:8081/api/mail/send

# Optional: default SMTP fallback (users can override via Profile UI)
DEFAULT_SMTP_HOST=smtp.gmail.com
DEFAULT_SMTP_PORT=587
DEFAULT_SMTP_USER=
DEFAULT_SMTP_PASS=
